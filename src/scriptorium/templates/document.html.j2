<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Scriptorium Export</title>
  <style>
    @page {
      size: {{ document.pages[0].width_pt }}pt {{ document.pages[0].height_pt }}pt;
      margin: 0;
    }
    :root {
      color-scheme: light;
      --page-gap: 24px;
      --overlay-border: rgba(29, 97, 179, 0.65);
      --overlay-fill: rgba(255, 255, 255, 0.68);
      --debug-fill: rgba(255, 214, 102, 0.16);
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      background: #777;
      font-family: Arial, sans-serif;
    }
    .document {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--page-gap);
      padding: var(--page-gap);
    }
    .page {
      position: relative;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 2px 18px rgba(0, 0, 0, 0.28);
      flex: 0 0 auto;
    }
    .page-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: fill;
      user-select: none;
      pointer-events: none;
    }
    .element {
      position: absolute;
      overflow: hidden;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      color: var(--text-color, #111);
      line-height: var(--line-height, 1.15);
      font-family: var(--font-family, serif);
      font-size: var(--font-size, 12px);
      font-weight: var(--font-weight, 400);
      font-style: var(--font-style, normal);
      z-index: 1;
    }
    body.mode-background .element {
      display: none;
    }
    body.mode-structured {
      background: #777;
    }
    body.mode-structured .element {
      border: 0;
      background: transparent;
      color: var(--text-color, #111);
      outline: 0;
    }
    body.mode-structured .element:not([data-type="shape"]) {
      overflow: visible;
      white-space: pre;
      text-align: justify;
      text-align-last: justify;
    }
    body.mode-fidelity .element {
      border: 0;
      background: transparent;
      outline: 0;
    }
    body.mode-fidelity .element[data-scriptorium-editable="false"] {
      display: none;
    }
    body.mode-fidelity .element[data-scriptorium-editable="true"] {
      color: transparent !important;
      caret-color: var(--text-color, #111);
      -webkit-text-fill-color: transparent;
    }
    body.mode-fidelity .element[data-scriptorium-editable="true"] .text-run {
      color: transparent !important;
      -webkit-text-fill-color: transparent;
    }
    body.mode-fidelity .element[data-scriptorium-has-replacement="true"] {
      color: var(--text-color, #111) !important;
      -webkit-text-fill-color: currentColor;
      background: var(--replacement-mask-color, #fff);
      padding: var(--replacement-padding-top, 0px) var(--replacement-padding-right, 0px) var(--replacement-padding-bottom, 0px) var(--replacement-padding-left, 0px);
      font-size: calc(var(--font-size, 12px) * var(--replacement-fit-scale, 1));
      line-height: var(--replacement-line-height, var(--line-height, 1.15));
      overflow: hidden;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
    body.mode-fidelity .element[data-scriptorium-has-replacement="true"] .text-run {
      color: inherit !important;
      -webkit-text-fill-color: currentColor;
    }
    body.mode-fidelity .element[data-scriptorium-editable="true"]:hover,
    body.mode-fidelity .element[data-scriptorium-editable="true"]:focus {
      color: var(--text-color, #111) !important;
      -webkit-text-fill-color: currentColor;
      background: rgba(255, 255, 255, 0.78);
      outline: 2px solid rgba(29, 97, 179, 0.74);
      outline-offset: 1px;
    }
    body.mode-fidelity .element[data-scriptorium-editable="true"]:hover .text-run,
    body.mode-fidelity .element[data-scriptorium-editable="true"]:focus .text-run {
      color: inherit !important;
      -webkit-text-fill-color: currentColor;
    }
    .text-run {
      white-space: pre;
    }
    .element.text-fit {
      overflow: hidden;
      white-space: normal;
      text-align: left !important;
      text-align-last: auto !important;
    }
    .text-fit-layer {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
      pointer-events: none;
    }
    .editable-text-proxy {
      position: absolute;
      inset: 0;
      display: block;
      overflow: visible;
      white-space: pre;
      color: transparent;
      -webkit-text-fill-color: transparent;
      pointer-events: auto;
    }
    body.mode-structured .element.text-fit:focus-within .text-fit-layer,
    body.mode-structured .element.text-fit[data-scriptorium-live-replacement="true"] .text-fit-layer {
      opacity: 0.18;
    }
    body.mode-structured .element.text-fit:focus-within .editable-text-proxy {
      color: var(--text-color, #111);
      -webkit-text-fill-color: currentColor;
      background: rgba(255, 255, 255, 0.82);
    }
    body.mode-structured .element.text-fit[data-scriptorium-live-replacement="true"] .text-fit-layer {
      display: none;
    }
    .element.positioned-runs {
      overflow: hidden !important;
      white-space: normal;
      text-align: left;
      text-align-last: auto;
    }
    .element.positioned-runs .text-run {
      position: absolute;
      display: block;
      overflow: visible;
      line-height: 1;
      transform-origin: left top;
    }
    body.mode-structured .element:focus {
      outline: 2px solid rgba(29, 97, 179, 0.82);
      outline-offset: 2px;
      background: rgba(255, 255, 255, 0.82);
    }
    body.mode-structured .element[data-scriptorium-source="native-ocr"] {
      color: transparent !important;
      caret-color: var(--text-color, #111);
      -webkit-text-fill-color: transparent;
      text-align: left;
      text-align-last: auto;
    }
    body.mode-structured .element[data-scriptorium-source="native-ocr"] .text-run {
      color: transparent !important;
      -webkit-text-fill-color: transparent;
    }
    body.mode-structured .element[data-scriptorium-source="native-ocr"]:hover,
    body.mode-structured .element[data-scriptorium-source="native-ocr"]:focus {
      color: var(--text-color, #111) !important;
      -webkit-text-fill-color: currentColor;
      background: rgba(255, 255, 255, 0.78);
      outline: 2px solid rgba(29, 97, 179, 0.74);
      outline-offset: 1px;
    }
    body.mode-structured .element[data-scriptorium-source="native-ocr"]:hover .text-run,
    body.mode-structured .element[data-scriptorium-source="native-ocr"]:focus .text-run {
      color: inherit !important;
      -webkit-text-fill-color: currentColor;
    }
    body.mode-debug .element {
      border: 1px solid var(--overlay-border);
      background: var(--debug-fill);
      color: transparent;
    }
    body.mode-source .element,
    body.mode-edited .element,
    body.mode-translated .element,
    body.mode-bilingual .element {
      border: 1px solid transparent;
      background: transparent;
    }
    body.mode-source.show-boxes .element,
    body.mode-edited.show-boxes .element,
    body.mode-translated.show-boxes .element,
    body.mode-bilingual.show-boxes .element {
      border-color: var(--overlay-border);
      background: var(--overlay-fill);
    }
    .element[data-type="table"],
    .element[data-type="figure"],
    .element[data-type="formula"],
    .element[data-type="image"],
    .element[data-type="shape"] {
      color: transparent;
    }
    .element[data-type="shape"] {
      z-index: 0;
      pointer-events: none;
      background: var(--fill-color, transparent);
      border: var(--border-width, 0px) solid var(--stroke-color, transparent);
    }
    .element[data-scriptorium-shape-line="true"] {
      overflow: visible;
      background: transparent;
      border: 0;
    }
    .element[data-scriptorium-shape-path="true"] {
      overflow: visible;
      background: transparent;
      border: 0;
    }
    .shape-line {
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
    }
    .shape-vector {
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
    }
    .element[data-type="image"] {
      z-index: 0;
      pointer-events: none;
    }
    .embedded-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: fill;
      user-select: none;
      pointer-events: none;
    }
    body.mode-structured .element[data-type="shape"] {
      background: var(--fill-color, transparent);
      border: var(--border-width, 0px) solid var(--stroke-color, transparent);
    }
    body.mode-structured .element[data-scriptorium-shape-line="true"] {
      background: transparent;
      border: 0;
    }
    body.mode-structured .element[data-scriptorium-shape-path="true"] {
      background: transparent;
      border: 0;
    }
    .element-label {
      display: none;
      position: absolute;
      left: 0;
      top: 0;
      transform: translateY(-100%);
      padding: 2px 5px;
      border-radius: 3px 3px 0 0;
      background: rgba(29, 97, 179, 0.88);
      color: #fff;
      font: 10px/1.2 Arial, sans-serif;
    }
    body.mode-debug .element-label {
      display: block;
    }
    @media print {
      html, body { background: #fff; }
      .document {
        display: block;
        padding: 0;
        font-size: 0;
        line-height: 0;
      }
      .page {
        display: block;
        width: var(--page-width-pt) !important;
        height: var(--page-height-pt) !important;
        margin: 0;
        box-shadow: none;
        break-after: auto;
        page-break-after: auto;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page + .page {
        break-before: page;
        page-break-before: always;
      }
      body.mode-fidelity .element {
        display: none !important;
      }
      body.mode-fidelity .element[data-scriptorium-has-replacement="true"] {
        display: block !important;
        left: var(--print-left) !important;
        top: var(--print-top) !important;
        width: var(--print-width) !important;
        height: var(--print-height) !important;
        overflow: hidden;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        text-align: left;
        text-align-last: auto;
        color: var(--text-color, #111) !important;
        -webkit-text-fill-color: currentColor;
        background: var(--replacement-mask-color, #fff);
        padding: var(--print-replacement-padding-top, var(--replacement-padding-top, 0px)) var(--print-replacement-padding-right, var(--replacement-padding-right, 0px)) var(--print-replacement-padding-bottom, var(--replacement-padding-bottom, 0px)) var(--print-replacement-padding-left, var(--replacement-padding-left, 0px));
        font-size: calc(var(--print-font-size, var(--font-size, 12px)) * var(--replacement-fit-scale, 1));
        line-height: var(--replacement-line-height, var(--line-height, 1.15));
        outline: 0;
        z-index: 2;
      }
      .element.text-fit .editable-text-proxy {
        display: none;
      }
    }
  </style>
</head>
<body class="mode-{{ display_mode }}" data-document-id="{{ document.id }}">
  <main class="document">
    {% for page in pages %}
    {% set page_ir = page.ir %}
    {% set layout_scale = 1.3333333333333333 if display_mode == 'structured' else 1 %}
    {% set print_layout_scale = 96 / page_ir.render_dpi if display_mode == 'fidelity' else 1 %}
    {% set page_width = page_ir.width_pt * layout_scale if display_mode == 'structured' else page_ir.width_px %}
    {% set page_height = page_ir.height_pt * layout_scale if display_mode == 'structured' else page_ir.height_px %}
    <section
      class="page"
      data-page-index="{{ page_ir.page_index }}"
      style="
        width: {{ '%.3f'|format(page_width) }}px;
        height: {{ '%.3f'|format(page_height) }}px;
        --page-width-pt: {{ page_ir.width_pt }}pt;
        --page-height-pt: {{ page_ir.height_pt }}pt;
      "
    >
      {% if page.background %}
      <img class="page-bg" src="{{ page.background }}" alt="">
      {% endif %}
      {% for wrapped in page.elements %}
      {% set element = wrapped.ir %}
      {% set box = element.bbox_pdf if display_mode == 'structured' else element.bbox_px %}
      {% set border_width = element.style_hint.get('border_width_pt', 0) * layout_scale if display_mode == 'structured' else element.style_hint.get('border_width_px', 0) %}
      {% set is_text_node = element.source_text|length > 0 %}
      {% set text_runs = element_text_runs(element, display_mode) %}
      {% set has_replacement = has_replacement_text(element, display_mode) %}
      {% set replacement = wrapped.replacement %}
      {% set render_box = replacement.mask_bbox if replacement else box %}
      {% set use_svg_text_fit = should_use_svg_text_fit(element, display_mode, text_fit) %}
      {% set svg_text_fit = svg_text_fit_geometry(element, display_mode) if use_svg_text_fit else none %}
      {% set use_positioned_runs = text_runs and should_position_text_runs(element, display_mode) and not use_svg_text_fit %}
      {% set element_crop = wrapped.crop %}
      {% set line_shape = shape_line(element) %}
      {% set vector_shape = shape_path(element) %}
      <div
        id="{{ element.id }}"
        class="element editable-node{% if use_positioned_runs %} positioned-runs{% endif %}{% if use_svg_text_fit %} text-fit{% endif %}"
        data-id="{{ element.id }}"
        data-type="{{ element.type }}"
        data-scriptorium-element-id="{{ element.id }}"
        data-scriptorium-role="{{ annotation_attr(element, 'role') }}"
        data-scriptorium-source="{{ annotation_attr(element, 'source_kind') }}"
        data-scriptorium-style-id="{{ annotation_attr(element, 'style_id') }}"
        data-scriptorium-layout-group="{{ annotation_attr(element, 'layout_group_id') }}"
        data-scriptorium-layout-kind="{{ annotation_attr(element, 'layout_group_kind') }}"
        data-scriptorium-layout-confidence="{{ annotation_attr(element, 'layout_group_confidence') }}"
        data-scriptorium-shape-geometry="{{ annotation_attr(element, 'shape_geometry') }}"
        data-scriptorium-shape-line="{{ 'true' if line_shape else 'false' }}"
        data-scriptorium-shape-path="{{ 'true' if vector_shape else 'false' }}"
        data-scriptorium-text-fit="{{ 'svg' if use_svg_text_fit else 'none' }}"
        data-scriptorium-editable="{{ 'true' if is_text_node else 'false' }}"
        data-scriptorium-edit-target="{{ 'edited_text' if is_text_node else '' }}"
        data-scriptorium-translation-target="{{ 'translated_text' if is_text_node else '' }}"
        data-scriptorium-source-text="{{ element.source_text }}"
        data-scriptorium-edited-text="{{ element.edited_text if element.edited_text is not none else '' }}"
        data-scriptorium-translated-text="{{ element.translated_text if element.translated_text is not none else '' }}"
        data-scriptorium-active-text-target="{{ 'translated_text' if display_mode == 'translated' or element.translated_text is not none else 'edited_text' }}"
        data-scriptorium-has-replacement="{{ 'true' if has_replacement else 'false' }}"
        data-scriptorium-replacement-policy="{{ replacement.policy if replacement else '' }}"
        data-scriptorium-replacement-fit-scale="{{ replacement.fit_scale if replacement else '' }}"
        data-scriptorium-replacement-overflow="{{ 'true' if replacement and replacement.overflow else 'false' }}"
        data-scriptorium-replacement-estimated-overflow="{{ 'true' if replacement and replacement.estimated_overflow else 'false' }}"
        data-scriptorium-replacement-rendered-overflow=""
        data-scriptorium-replacement-rendered-fit-scale=""
        data-scriptorium-replacement-rendered-line-height=""
        data-scriptorium-replacement-rendered-fit-policy=""
        data-scriptorium-replacement-conflict="{{ 'true' if replacement and replacement.conflict else 'false' }}"
        data-scriptorium-replacement-conflict-ids="{{ replacement.conflict_summary if replacement else '' }}"
        data-scriptorium-replacement-mask-padding="{{ replacement.padding_top if replacement else '' }},{{ replacement.padding_right if replacement else '' }},{{ replacement.padding_bottom if replacement else '' }},{{ replacement.padding_left if replacement else '' }}"
        data-scriptorium-replacement-mask-color="{{ replacement.mask_color if replacement else '' }}"
        data-scriptorium-replacement-mask-color-source="{{ replacement.mask_color_source if replacement else '' }}"
        data-scriptorium-replacement-padding-constrained="{{ 'true' if replacement and replacement.padding_constrained else 'false' }}"
        data-scriptorium-replacement-padding-constraint-ids="{{ replacement.padding_constraint_ids|join(',') if replacement else '' }}"
        data-scriptorium-replacement-padding-constraints="{{ replacement.padding_constraint_summary if replacement else '' }}"
        data-bbox-pdf="{{ element.bbox_pdf.as_list()|join(',') }}"
        data-bbox-px="{{ element.bbox_px.as_list()|join(',') }}"
        data-xml-node="element"
        data-ir-path="/pages/{{ page_ir.page_index }}/elements/{{ loop.index0 }}"
        data-reading-order="{{ element.reading_order }}"
        data-scriptorium-semantic-order="{{ annotation_attr(element, 'semantic_order') }}"
        data-scriptorium-visual-order="{{ annotation_attr(element, 'visual_order') }}"
        data-scriptorium-column-index="{{ annotation_attr(element, 'column_index') }}"
        data-scriptorium-column-count="{{ annotation_attr(element, 'column_count') }}"
        data-scriptorium-column-span="{{ annotation_attr(element, 'column_span') }}"
        data-scriptorium-flow-segment="{{ annotation_attr(element, 'flow_segment_index') }}"
        data-scriptorium-reading-order-strategy="{{ annotation_attr(element, 'reading_order_strategy') }}"
        data-scriptorium-reading-order-region="{{ annotation_attr(element, 'reading_order_region_path') }}"
        data-scriptorium-reading-order-scope="{{ annotation_attr(element, 'reading_order_scope') }}"
        data-scriptorium-reading-order-artifact="{{ annotation_attr(element, 'reading_order_artifact_type') }}"
        data-scriptorium-reading-order-sidebar="{{ annotation_attr(element, 'reading_order_sidebar_type') }}"
        data-scriptorium-reading-order-caption="{{ annotation_attr(element, 'reading_order_caption_type') }}"
        data-scriptorium-reading-order-stream-id="{{ annotation_attr(element, 'reading_order_stream_id') }}"
        data-scriptorium-reading-order-stream-type="{{ annotation_attr(element, 'reading_order_stream_type') }}"
        data-scriptorium-reading-order-stream-index="{{ annotation_attr(element, 'reading_order_stream_index') }}"
        data-scriptorium-translation-stream-id="{{ annotation_attr(element, 'reading_order_stream_id') }}"
        data-scriptorium-translation-stream-type="{{ annotation_attr(element, 'reading_order_stream_type') }}"
        data-scriptorium-caption-target-id="{{ annotation_attr(element, 'reading_order_caption_target_id') }}"
        data-scriptorium-caption-target-kind="{{ annotation_attr(element, 'reading_order_caption_target_kind') }}"
        data-scriptorium-caption-target-source="{{ annotation_attr(element, 'reading_order_caption_target_source') }}"
        data-scriptorium-caption-target-position="{{ annotation_attr(element, 'reading_order_caption_target_position') }}"
        data-scriptorium-caption-target-distance="{{ annotation_attr(element, 'reading_order_caption_target_distance_pt') }}"
        data-scriptorium-caption-target-confidence="{{ annotation_attr(element, 'reading_order_caption_target_confidence') }}"
        data-scriptorium-reading-order-confidence="{{ annotation_attr(element, 'reading_order_confidence') }}"
        data-scriptorium-reading-order-evidence="{{ annotation_attr(element, 'reading_order_evidence_summary') }}"
        contenteditable="{{ 'true' if is_text_node and not use_svg_text_fit and display_mode in ['structured', 'source', 'edited', 'translated', 'bilingual', 'fidelity'] else 'false' }}"
        spellcheck="false"
        style="
          left: {{ '%.3f'|format(render_box.x0 * layout_scale) }}px;
          top: {{ '%.3f'|format(render_box.y0 * layout_scale) }}px;
          width: {{ '%.3f'|format(render_box.width * layout_scale) }}px;
          height: {{ '%.3f'|format(render_box.height * layout_scale) }}px;
          --print-left: {{ '%.3f'|format(render_box.x0 * print_layout_scale) }}px;
          --print-top: {{ '%.3f'|format(render_box.y0 * print_layout_scale) }}px;
          --print-width: {{ '%.3f'|format(render_box.width * print_layout_scale) }}px;
          --print-height: {{ '%.3f'|format(render_box.height * print_layout_scale) }}px;
          --font-size: {{ element.style_hint.get('font_size_px', 12) }}px;
          --print-font-size: {{ '%.4f'|format(element.style_hint.get('font_size_px', 12) * print_layout_scale) }}px;
          --line-height: {{ element.style_hint.get('line_height', 1.15) }};
          --font-family: {{ element.style_hint.get('font_family', 'serif') }};
          --font-weight: {{ element.style_hint.get('font_weight', 400) }};
          --font-style: {{ element.style_hint.get('font_style', 'normal') }};
          --text-color: {{ element.style_hint.get('text_color', '#111') }};
          --fill-color: {{ element.style_hint.get('fill_color', 'transparent') }};
          --stroke-color: {{ element.style_hint.get('stroke_color', 'transparent') }};
          --border-width: {{ border_width }}px;
          --replacement-fit-scale: {{ replacement.fit_scale if replacement else 1 }};
          --replacement-padding-top: {{ replacement.padding_top if replacement else 0 }}px;
          --replacement-padding-right: {{ replacement.padding_right if replacement else 0 }}px;
          --replacement-padding-bottom: {{ replacement.padding_bottom if replacement else 0 }}px;
          --replacement-padding-left: {{ replacement.padding_left if replacement else 0 }}px;
          --replacement-mask-color: {{ replacement.mask_color if replacement else '#fff' }};
          --print-replacement-padding-top: {{ '%.4f'|format((replacement.padding_top if replacement else 0) * print_layout_scale) }}px;
          --print-replacement-padding-right: {{ '%.4f'|format((replacement.padding_right if replacement else 0) * print_layout_scale) }}px;
          --print-replacement-padding-bottom: {{ '%.4f'|format((replacement.padding_bottom if replacement else 0) * print_layout_scale) }}px;
          --print-replacement-padding-left: {{ '%.4f'|format((replacement.padding_left if replacement else 0) * print_layout_scale) }}px;
        "
      ><span class="element-label">{{ element.type }} #{{ element.reading_order }}</span>{% if line_shape %}<svg class="shape-line" viewBox="0 0 {{ line_shape.width }} {{ line_shape.height }}" preserveAspectRatio="none" aria-hidden="true"><line x1="{{ line_shape.x0 }}" y1="{{ line_shape.y0 }}" x2="{{ line_shape.x1 }}" y2="{{ line_shape.y1 }}" stroke="{{ element.style_hint.get('stroke_color', 'transparent') }}" stroke-width="{{ element.style_hint.get('border_width_pt', 1) }}" stroke-opacity="{{ annotation_attr(element, 'stroke_opacity', '1') }}" stroke-linecap="butt"></line></svg>{% elif vector_shape %}<svg class="shape-vector" viewBox="0 0 {{ vector_shape.width }} {{ vector_shape.height }}" preserveAspectRatio="none" aria-hidden="true"><path d="{{ vector_shape.path }}" fill="{{ element.style_hint.get('fill_color', 'transparent') }}" fill-opacity="{{ annotation_attr(element, 'fill_opacity', '1') }}" fill-rule="{{ vector_shape.fill_rule }}" stroke="{{ element.style_hint.get('stroke_color', 'transparent') }}" stroke-width="{{ vector_shape.stroke_width }}" stroke-opacity="{{ annotation_attr(element, 'stroke_opacity', '1') }}" stroke-linecap="butt" stroke-linejoin="miter"></path></svg>{% elif element.type == 'image' and element_crop %}<img class="embedded-image" src="{{ element_crop }}" alt="" draggable="false">{% elif use_svg_text_fit and svg_text_fit %}<svg class="text-fit-layer" viewBox="0 0 {{ svg_text_fit.width }} {{ svg_text_fit.height }}" preserveAspectRatio="none" aria-hidden="true">{% for run in svg_text_fit.runs %}<text xml:space="preserve" x="{{ run.x }}" y="{{ run.y }}" textLength="{{ run.text_length }}" lengthAdjust="spacingAndGlyphs" fill="{{ run.text_color }}" font-family="{{ run.font_family }}" font-size="{{ run.font_size }}" font-weight="{{ run.font_weight }}" font-style="{{ run.font_style }}">{{ run.text }}</text>{% endfor %}</svg><span class="editable-text-proxy" contenteditable="{{ 'true' if is_text_node and display_mode in ['structured', 'source', 'edited', 'translated', 'bilingual', 'fidelity'] else 'false' }}" spellcheck="false">{{ element_text(element, display_mode) }}</span>{% elif text_runs %}{% for run in text_runs %}{% set run_style = run.style %}{% set run_box = run.bbox_pdf if display_mode == 'structured' else run.bbox_px %}<span
          class="text-run"
          data-scriptorium-run-index="{{ run.index }}"
          data-scriptorium-run-style-id="{{ run.style_id }}"
          data-scriptorium-run-script="{{ run.script }}"
          data-bbox-pdf="{{ run.bbox_pdf|join(',') }}"
          data-bbox-px="{{ run.bbox_px|join(',') }}"
          style="
            font-family: {{ run_style.get('font_family', element.style_hint.get('font_family', 'serif')) }};
            font-size: {{ run_style.get('font_size_px', element.style_hint.get('font_size_px', 12)) }}px;
            font-weight: {{ run_style.get('font_weight', element.style_hint.get('font_weight', 400)) }};
            font-style: {{ run_style.get('font_style', element.style_hint.get('font_style', 'normal')) }};
            color: {{ run_style.get('text_color', element.style_hint.get('text_color', '#111')) }};
            vertical-align: {{ run_style.get('vertical_align', 'baseline') }};
            {% if use_positioned_runs %}
            left: {{ '%.3f'|format((run_box[0] - box.x0) * layout_scale) }}px;
            top: {{ '%.3f'|format((run_box[1] - box.y0) * layout_scale) }}px;
            width: {{ '%.3f'|format((run_box[2] - run_box[0]) * layout_scale) }}px;
            height: {{ '%.3f'|format((run_box[3] - run_box[1]) * layout_scale) }}px;
            {% endif %}
          "
        >{{ run.text }}</span>{% endfor %}{% else %}{{ element_text(element, display_mode) }}{% endif %}</div>
      {% endfor %}
    </section>
    {% endfor %}
  </main>
  <script>
    (() => {
      const replacementSelector = '.element[data-scriptorium-has-replacement="true"]';
      const minScale = 0.62;
      const minLineHeight = 1.0;
      const measurementTolerance = 1;

      function number(value, fallback) {
        const parsed = Number.parseFloat(value);
        return Number.isFinite(parsed) ? parsed : fallback;
      }

      function declaredScale(owner) {
        return Math.max(minScale, Math.min(1, number(owner.dataset.scriptoriumReplacementFitScale, 1)));
      }

      function declaredLineHeight(owner) {
        const inline = owner.style.getPropertyValue("--line-height");
        const computed = getComputedStyle(owner).getPropertyValue("--line-height");
        return Math.max(minLineHeight, number(inline || computed, 1.15));
      }

      function hasOverflow(owner) {
        return owner.scrollWidth > owner.clientWidth + measurementTolerance
          || owner.scrollHeight > owner.clientHeight + measurementTolerance;
      }

      function setFit(owner, scale, lineHeight) {
        owner.style.setProperty("--replacement-fit-scale", scale.toFixed(4));
        owner.style.setProperty("--replacement-line-height", lineHeight.toFixed(4));
      }

      function maxFittingScale(owner, lineHeight) {
        setFit(owner, minScale, lineHeight);
        if (hasOverflow(owner)) {
          return { scale: minScale, fits: false };
        }
        setFit(owner, 1, lineHeight);
        if (!hasOverflow(owner)) {
          return { scale: 1, fits: true };
        }
        let low = minScale;
        let high = 1;
        for (let iteration = 0; iteration < 12; iteration += 1) {
          const middle = (low + high) / 2;
          setFit(owner, middle, lineHeight);
          if (hasOverflow(owner)) {
            high = middle;
          } else {
            low = middle;
          }
        }
        return { scale: low, fits: true };
      }

      function reset(owner) {
        owner.style.setProperty("--replacement-fit-scale", declaredScale(owner).toFixed(4));
        owner.style.removeProperty("--replacement-line-height");
        owner.dataset.scriptoriumReplacementRenderedOverflow = "";
        owner.dataset.scriptoriumReplacementRenderedFitScale = "";
        owner.dataset.scriptoriumReplacementRenderedLineHeight = "";
        owner.dataset.scriptoriumReplacementRenderedFitPolicy = "";
        owner.dataset.scriptoriumReplacementOverflow = owner.dataset.scriptoriumReplacementEstimatedOverflow || "false";
      }

      function fit(owner) {
        if (!owner || owner.dataset.scriptoriumHasReplacement !== "true") {
          if (owner) {
            reset(owner);
          }
          return null;
        }

        const lineHeight = declaredLineHeight(owner);
        let selected = {
          ...maxFittingScale(owner, lineHeight),
          lineHeight,
        };
        if (lineHeight > minLineHeight) {
          const compact = {
            ...maxFittingScale(owner, minLineHeight),
            lineHeight: minLineHeight,
          };
          if (compact.fits && compact.scale > selected.scale + 0.01) {
            selected = compact;
          }
        }

        setFit(owner, selected.scale, selected.lineHeight);
        const overflow = hasOverflow(owner);
        owner.dataset.scriptoriumReplacementRenderedOverflow = overflow ? "true" : "false";
        owner.dataset.scriptoriumReplacementRenderedFitScale = selected.scale.toFixed(4);
        owner.dataset.scriptoriumReplacementRenderedLineHeight = selected.lineHeight.toFixed(4);
        owner.dataset.scriptoriumReplacementRenderedFitPolicy = "browser-layout-v1";
        owner.dataset.scriptoriumReplacementOverflow = overflow ? "true" : "false";
        return {
          overflow,
          scale: selected.scale,
          lineHeight: selected.lineHeight,
          fits: selected.fits,
        };
      }

      function fitAll() {
        return Array.from(document.querySelectorAll(replacementSelector)).map(fit).filter(Boolean);
      }

      fitAll();
      const fontReady = document.fonts && document.fonts.ready ? document.fonts.ready : Promise.resolve();
      const ready = Promise.resolve(fontReady).catch(() => undefined).then(() => fitAll());
      window.addEventListener("beforeprint", fitAll);
      const printMedia = window.matchMedia && window.matchMedia("print");
      if (printMedia && printMedia.addEventListener) {
        printMedia.addEventListener("change", event => {
          if (event.matches) {
            fitAll();
          }
        });
      }
      window.ScriptoriumFitting = Object.freeze({ fit, fitAll, reset, ready });
    })();
  </script>
  <script>
    (() => {
      const format = "scriptorium-html-edits/v1";
      const editableSelector = '[data-scriptorium-editable="true"]';
      const editableTargets = new Set(["edited_text", "translated_text"]);
      const originalStates = new Map();
      const changed = new Map();
      const documentId = document.body.dataset.documentId || "document";
      const storageKey = `scriptorium-html-edits:${documentId}`;

      function normalizeText(value) {
        return String(value || "").replace(/\r\n?/g, "\n");
      }

      function ownerFor(node) {
        return node instanceof Element ? node.closest(editableSelector) : null;
      }

      function proxyFor(owner) {
        return owner.querySelector(":scope > .editable-text-proxy");
      }

      function readText(owner) {
        const target = proxyFor(owner) || owner;
        return normalizeText(target.innerText);
      }

      function remember(owner) {
        if (originalStates.has(owner)) {
          return originalStates.get(owner);
        }
        const state = {
          html: owner.innerHTML,
          replacement: owner.dataset.scriptoriumHasReplacement || "false",
          liveReplacement: owner.dataset.scriptoriumLiveReplacement || "false",
          activeTarget: owner.dataset.scriptoriumActiveTextTarget || "edited_text",
          editedText: owner.dataset.scriptoriumEditedText || "",
          translatedText: owner.dataset.scriptoriumTranslatedText || "",
        };
        originalStates.set(owner, state);
        return state;
      }

      function targetFor(owner) {
        const target = owner.dataset.scriptoriumActiveTextTarget || owner.dataset.scriptoriumEditTarget;
        return editableTargets.has(target) ? target : "edited_text";
      }

      function updateTextMetadata(owner, target, text) {
        if (target === "translated_text") {
          owner.dataset.scriptoriumTranslatedText = text;
        } else {
          owner.dataset.scriptoriumEditedText = text;
        }
      }

      function patchEntry(owner, text, target) {
        return {
          element_id: owner.dataset.scriptoriumElementId || owner.id,
          target,
          text,
          source_text: owner.dataset.scriptoriumSourceText || "",
        };
      }

      function emitEdit(entry) {
        const detail = { format, document_id: documentId, edit: entry };
        window.dispatchEvent(new CustomEvent("scriptorium:edit", { detail }));
        if (window.parent !== window) {
          const targetOrigin = window.location.origin === "null" ? "*" : window.location.origin;
          window.parent.postMessage({ type: "scriptorium:edit", detail }, targetOrigin);
        }
      }

      function collect() {
        return {
          format,
          document_id: documentId,
          edits: Array.from(changed.values()),
        };
      }

      function persist() {
        try {
          sessionStorage.setItem(storageKey, JSON.stringify(collect()));
        } catch (error) {
          // Static exports remain usable when browser storage is unavailable.
        }
      }

      function record(owner, text, { persistEdit = true, emit = true } = {}) {
        const sourceText = owner.dataset.scriptoriumSourceText || "";
        const target = targetFor(owner);
        const id = owner.dataset.scriptoriumElementId || owner.id;
        if (!id) {
          return;
        }
        const isSourceText = text === sourceText;
        owner.dataset.scriptoriumHasReplacement = isSourceText ? "false" : "true";
        owner.dataset.scriptoriumLiveReplacement = isSourceText ? "false" : "true";
        updateTextMetadata(owner, target, text);
        if (isSourceText) {
          changed.delete(id);
        } else {
          const entry = patchEntry(owner, text, target);
          changed.set(id, entry);
          if (emit) {
            emitEdit(entry);
          }
        }
        if (persistEdit) {
          persist();
        }
        if (window.ScriptoriumFitting) {
          window.ScriptoriumFitting.fit(owner);
        }
      }

      function setText(owner, text) {
        const proxy = proxyFor(owner);
        if (proxy) {
          proxy.textContent = text;
          return;
        }
        const label = owner.querySelector(":scope > .element-label");
        const fragment = document.createDocumentFragment();
        if (label) {
          fragment.append(label.cloneNode(true));
        }
        fragment.append(document.createTextNode(text));
        owner.replaceChildren(fragment);
      }

      function apply(patch, { persistEdit = true } = {}) {
        if (!patch || patch.format !== format || !Array.isArray(patch.edits)) {
          throw new Error("Expected a Scriptorium HTML edit patch.");
        }
        if (patch.document_id && patch.document_id !== documentId) {
          throw new Error("Edit patch belongs to a different document.");
        }
        let applied = 0;
        for (const entry of patch.edits) {
          if (!entry || !editableTargets.has(entry.target) || typeof entry.element_id !== "string" || typeof entry.text !== "string") {
            continue;
          }
          const owner = document.getElementById(entry.element_id);
          if (!owner || owner.dataset.scriptoriumEditable !== "true") {
            continue;
          }
          remember(owner);
          owner.dataset.scriptoriumActiveTextTarget = entry.target;
          setText(owner, entry.text);
          record(owner, entry.text, { persistEdit: false, emit: false });
          applied += 1;
        }
        if (persistEdit) {
          persist();
        }
        return applied;
      }

      function reset() {
        for (const owner of document.querySelectorAll(editableSelector)) {
          const original = originalStates.get(owner);
          if (!original) {
            continue;
          }
          owner.innerHTML = original.html;
          owner.dataset.scriptoriumHasReplacement = original.replacement;
          owner.dataset.scriptoriumLiveReplacement = original.liveReplacement;
          owner.dataset.scriptoriumActiveTextTarget = original.activeTarget;
          owner.dataset.scriptoriumEditedText = original.editedText;
          owner.dataset.scriptoriumTranslatedText = original.translatedText;
          if (window.ScriptoriumFitting) {
            window.ScriptoriumFitting.fit(owner);
          }
        }
        changed.clear();
        try {
          sessionStorage.removeItem(storageKey);
        } catch (error) {
          // Storage is optional for standalone static exports.
        }
      }

      function download(filename = `${documentId}.scriptorium-edits.json`) {
        const blob = new Blob([JSON.stringify(collect(), null, 2) + "\n"], { type: "application/json" });
        const href = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = href;
        anchor.download = filename;
        anchor.click();
        window.setTimeout(() => URL.revokeObjectURL(href), 0);
      }

      for (const owner of document.querySelectorAll(editableSelector)) {
        remember(owner);
      }
      document.addEventListener("input", (event) => {
        const owner = ownerFor(event.target);
        if (owner) {
          record(owner, readText(owner));
        }
      });
      try {
        const saved = sessionStorage.getItem(storageKey);
        if (saved) {
          apply(JSON.parse(saved), { persistEdit: false });
        }
      } catch (error) {
        // A malformed or unavailable session cache must not prevent viewing the export.
      }
      window.ScriptoriumEdits = Object.freeze({ apply, collect, download, format, reset });
    })();
  </script>
</body>
</html>
